     if(dirExists.find(dir) == dirExists.end()) {
       Loci::stopWatch s ;
       s.start() ;
       Loci::debugout << "making directory " << dir << endl ;
       int fid = open(dir.c_str(),O_RDONLY) ;
       if(fid < 0)
