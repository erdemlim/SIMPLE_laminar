        cnt++ ;

        for(int i=1;i<msz;++i)
          if(cval[i] > cval[0]) {
            swap(cval[i],cval[0]) ;
            swap(cmap[i],cmap[0]) ;
          }
        for(int i=2;i<msz;++i)
          if(cval[i] > cval[1]) {
            swap(cval[i],cval[1]) ;
