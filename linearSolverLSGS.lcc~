      }

      const int dsz = dom.size() ;
      vector<int> index(dsz) ;
      Map toeqn ;
      toeqn.allocate(dom) ;
      int cnt = 0 ;
      // First number all equations owned by this processor
      const int nmyeqn = mydom.size() ;
      FORALL(mydom,ii) {
        index[cnt] = ii ;
