      //    cout << "nmyeqn=" << nmyeqn << ",rem = " << remainder.size() << endl ;
      vector<int> offsets(nmyeqn+1) ;
      offsets[0] = 0 ;
      cnt = 1 ;
      int totsz = 0 ;
