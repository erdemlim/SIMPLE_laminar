        const int lsz = L_lower_[ii].size() ;
        const int usz = L_upper_[ii].size() ;
        const int msz = lsz+usz ;
        totsz += msz ;
        offsets[cnt] = totsz ;
        cnt++ ;
      } ENDFORALL ;    

      vector<pair<int,int> > couples ;
      vector<int> neighbors(totsz) ;
      cnt = 0 ;
      FORALL(mydom,ii) {
        const int lsz = L_lower_[ii].size() ;
        const int usz = L_upper_[ii].size() ;
        const int msz = lsz+usz ;
        vector<int> cmap(msz) ;
