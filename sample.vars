// Variables for Lid Driven Cavity Problem

{
boundary_conditions: <
                 BC_1=viscousWall(Uwall = [1,0,0]),  //fixed walls
                 BC_2=viscousWall(Uwall = [0,0,0]),  //moving wall
                 BC_3=symmetry
>
// Time Step
//deltaT: 1000 // 10 second time-step

print_freq: 1
plot_freq: 1000
plot_modulo: 1000

stop_iter: 10000

mu: 0.001
density:1.0
pRelax: 0.3
uRelax: 0.7
dt: 1e-2

epsilon: 0.0001 

// Initial conditions:
mdotf_initial: 0.0
p_initial: 0.0
}
