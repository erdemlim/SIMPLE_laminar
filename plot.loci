     name_store("modelName",modelName) ;
     input("modelName") ;
     name_store("OUTPUT",OUTPUT) ;
     
     conditional("do_plot") ;
     constraint("pos") ;
     input("plot_postfix") ;
     input(var_name_time);
     constraint(constraint_name) ;
     output("OUTPUT") ;
   }
   
   void vector_node_output::compute(const sequence &seq) {
     dump_vector(seq,c2n,*plot_postfix,*modelName,
                 "vec",value_name) ;
   }
   
