$rule pointwise(OUTPUT<-cell2node(p),plot_postfix,modelName),
  constraint(pos),conditional(doPlot), option(disable_threading),
  prelude {
  dump_scalar(seq,$cell2node(p),*$plot_postfix,*$modelName,
	      "sca","pressure") ;
} ;

$rule pointwise(OUTPUT<-cell2node(pPrime),plot_postfix,modelName),
  constraint(pos),conditional(doPlot), option(disable_threading),
  prelude {
  dump_scalar(seq,$cell2node(pPrime),*$plot_postfix,*$modelName,
	      "sca","pPrime") ;
} ;



$rule pointwise(OUTPUT<-cell2node(uVel),plot_postfix,modelName),
  constraint(pos),conditional(doPlot), option(disable_threading),
  prelude {
  dump_scalar(seq,$cell2node(uVel),*$plot_postfix,*$modelName,
	      "sca","uVel") ;
} ;

